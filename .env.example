# =============================================================================
# Cryptographic Mosaic — Environment Configuration
# Copy this file to `.env` and fill in your credentials.
# Run `npm run config` to generate `config.runtime.js` for the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment mode
# -----------------------------------------------------------------------------
# development = Testnet default, local demo wallet enabled, verbose logging
# production  = Mainnet default, wallet-only signing (no seed input)
DEPLOYMENT_MODE=production

# Default XRPL network shown on load (mainnet | testnet)
DEFAULT_XRPL_NETWORK=mainnet

# Public URL of the deployed dApp (required for Xaman return URLs)
APP_URL=https://mosaico-criptografico.vercel.app

# -----------------------------------------------------------------------------
# XRPL wallet reference (optional — your Xaman wallet address, NOT the API key)
# -----------------------------------------------------------------------------
# XRPL_WALLET_ADDRESS=rYourWalletAddressHere

# -----------------------------------------------------------------------------
# Xaman / Xumm credentials — https://apps.xumm.dev/
# -----------------------------------------------------------------------------
# Create an application → copy API Key + API Secret (UUID format, e.g. xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
# NEVER put your XRPL address (r...) in XUMM_API_KEY — that is your wallet, not the developer API key.
#
# API Key    → safe for browser (injected into config.runtime.js at build time)
# API Secret → SERVER ONLY — set in Vercel vault via `npm run vault:sync`, never commit
XUMM_API_KEY=your-xumm-api-key-here
XUMM_API_SECRET=your-xumm-api-secret-here

# -----------------------------------------------------------------------------
# Optional overrides
# -----------------------------------------------------------------------------
ENABLE_LOCAL_DEMO=false

# Vercel project token (optional, for CLI deploys — never commit the real value)
# VERCEL_TOKEN=
