{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/verify", "destination": "/verify.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/xrp-ledger.toml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/toml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/(index.html)?",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(main\\.js|src/.*\\.js|styles\\.css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://xumm.app; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://xumm.app https://oauth2.xumm.app https://xaman.app wss://s.altnet.rippletest.net:51233 wss://testnet.xrpl-labs.com wss://s.altnet.rippletest.net:51234 wss://xrplcluster.com wss://s1.ripple.com wss://s2.ripple.com wss://xrpl.ws; img-src 'self' data: https://xumm.app; media-src 'self'; frame-src https://xumm.app https://xaman.app;"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
