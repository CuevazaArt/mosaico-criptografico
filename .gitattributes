# Set default behavior to automatically normalize line endings
* text=auto

# Enforce LF line endings for text/code files
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.md text eol=lf
*.yml text eol=lf

# Keep binary assets unchanged
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
